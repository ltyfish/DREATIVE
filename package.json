{
  "name": "dreative",
  "version": "0.5.1",
  "description": "Layout-first visual editor skill for coding CLIs: extract your app's UI into editable wireframes, tweak with drag-drop + ref images, then the agent applies the diff back to your code.",
  "type": "module",
  "bin": {
    "dreative": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "skill"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:ui",
    "prepublishOnly": "npm run build",
    "build:server": "tsc -p tsconfig.json",
    "build:ui": "vite build",
    "dev": "concurrently \"tsx watch src/cli/index.ts --no-open\" \"vite\"",
    "start": "node dist/cli/index.js"
  },
  "dependencies": {
    "esbuild": "^0.24.0",
    "express": "^4.21.0",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xyflow/react": "^12.3.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "zustand": "^5.0.0"
  }
}
