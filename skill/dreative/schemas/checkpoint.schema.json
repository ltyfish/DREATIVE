{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dreative.local/schemas/checkpoint.schema.json",
  "title": "Dreative Mid-Build Visual Checkpoint",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "capturedAt", "implementation", "baselineScreenshotPaths", "screenshotPaths", "critique", "meaningfulWeaknessFound", "refinements", "approval"],
  "properties": {
    "version": { "const": 1 }, "capturedAt": { "type": "string", "format": "date-time" },
    "implementation": { "type": "object", "additionalProperties": false, "required": ["hero", "coreSection", "desktop", "mobile", "primaryMotionLanguage"], "properties": { "hero": { "const": true }, "coreSection": { "const": true }, "desktop": { "const": true }, "mobile": { "const": true }, "primaryMotionLanguage": { "const": true } } },
    "baselineScreenshotPaths": { "$ref": "#/$defs/nonEmptyStrings" },
    "screenshotPaths": { "type": "object", "additionalProperties": false, "required": ["desktop", "mobile"], "properties": { "desktop": { "$ref": "#/$defs/nonEmptyStrings" }, "mobile": { "$ref": "#/$defs/nonEmptyStrings" } } },
    "critique": { "type": "object", "additionalProperties": false, "required": ["distinctiveness", "hierarchy", "brandVisibility", "signatureLegibility", "equityRetention", "saasTemplateRisk", "brandSwapRisk", "mobileAuthorship", "motionPurpose", "counterfactualStrength"], "properties": { "distinctiveness": { "$ref": "#/$defs/critique" }, "hierarchy": { "$ref": "#/$defs/critique" }, "brandVisibility": { "$ref": "#/$defs/critique" }, "signatureLegibility": { "$ref": "#/$defs/critique" }, "equityRetention": { "$ref": "#/$defs/critique" }, "saasTemplateRisk": { "$ref": "#/$defs/critique" }, "brandSwapRisk": { "$ref": "#/$defs/critique" }, "mobileAuthorship": { "$ref": "#/$defs/critique" }, "motionPurpose": { "$ref": "#/$defs/critique" }, "counterfactualStrength": { "$ref": "#/$defs/critique" } } },
    "meaningfulWeaknessFound": { "type": "boolean" },
    "refinements": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["finding", "change", "evidenceIds"], "properties": { "finding": { "type": "string", "minLength": 1 }, "change": { "type": "string", "minLength": 1 }, "evidenceIds": { "$ref": "#/$defs/nonEmptyStrings" } } } },
    "approval": { "type": "object", "additionalProperties": false, "required": ["status", "approvedAt", "transcriptReferences"], "properties": { "status": { "const": "approved" }, "approvedAt": { "type": "string", "format": "date-time" }, "transcriptReferences": { "$ref": "#/$defs/nonEmptyStrings" } } },
    "systemSpreadStartedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": { "nonEmptyStrings": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }, "critique": { "type": "string", "minLength": 20 } }
}
