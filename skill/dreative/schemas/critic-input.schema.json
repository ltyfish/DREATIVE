{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dreative.local/schemas/critic-input.schema.json",
  "title": "Dreative Independent Visual Critic Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generatedAt", "originalBrief", "userConstraints", "approvedConcept", "visualBlueprints", "intendedSignature", "baselineAvailable", "evidence", "contextPolicy"],
  "properties": {
    "version": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "originalBrief": { "type": "string", "minLength": 12 },
    "userConstraints": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "approvedConcept": { "type": "string", "minLength": 12 },
    "visualBlueprints": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["pageId", "sectionId", "blueprint"], "properties": { "pageId": { "type": "string", "minLength": 1 }, "sectionId": { "type": "string", "minLength": 1 }, "blueprint": { "type": "string", "minLength": 20 } } } },
    "intendedSignature": { "type": "string", "minLength": 6 },
    "ambition": { "enum": ["standard", "expressive", "award", "experimental"] },
    "selectedTreatments": { "type": "array", "items": { "enum": ["ux", "mobile", "refined", "motion", "interaction", "media", "3d", "immersive", "cinematic", "experimental"] } },
    "plannedPeaks": { "type": "array", "maxItems": 3, "items": { "type": "object", "required": ["id", "location", "plannedBehaviour", "startState", "activeState", "resolution", "inputRelationship", "mobileStrategy", "fallbackState"] } },
    "plannedMechanisms": { "type": "array", "items": { "type": "object", "required": ["id", "location", "primaryImplementation", "primaryAcceptance", "fallbackImplementation", "fallbackTrigger"] } },
    "baselineAvailable": { "type": "boolean" },
    "motionRequired": { "type": "boolean" },
    "motionMomentIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "verificationRunId": { "type": "string", "minLength": 1 },
    "buildIdentityHash": { "type": "string", "minLength": 64 },
    "independentCriticRequired": { "type": "boolean" },
    "evidence": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/evidence" } },
    "contextPolicy": { "type": "object", "additionalProperties": false, "required": ["firstPass", "excluded"], "properties": { "firstPass": { "const": "objective-only" }, "excluded": { "type": "array", "uniqueItems": true, "allOf": [
      { "contains": { "const": "builder-self-review" } }, { "contains": { "const": "implementation-rationale" } }, { "contains": { "const": "quality-claims" } }, { "contains": { "const": "difficulty-excuses" } }, { "contains": { "const": "builder-score" } }
    ], "items": { "enum": ["builder-self-review", "implementation-rationale", "quality-claims", "difficulty-excuses", "builder-score"] } } } }
  },
  "$defs": {
    "evidence": { "type": "object", "additionalProperties": false, "required": ["id", "kind", "description"], "properties": {
      "id": { "type": "string", "minLength": 1 }, "kind": { "enum": ["baseline-screenshot", "final-screenshot", "motion-recording", "interaction-recording", "state-capture", "browser-trace", "reduced-motion-capture", "live-url"] }, "description": { "type": "string", "minLength": 8 }, "artifactPath": { "type": "string", "minLength": 1 }, "url": { "type": "string", "minLength": 1 }, "pageId": { "type": "string", "minLength": 1 }, "motionMomentId": { "type": "string", "minLength": 1 }, "viewport": { "type": "object", "additionalProperties": false, "required": ["width", "height"], "properties": { "width": { "type": "number", "exclusiveMinimum": 0 }, "height": { "type": "number", "exclusiveMinimum": 0 } } }, "temporal": { "type": "object", "additionalProperties": false, "properties": { "startTimestamp": { "type": "string", "format": "date-time" }, "endTimestamp": { "type": "string", "format": "date-time" }, "controlledProgress": { "type": ["number", "string"] }, "observedProperties": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } }
    }, "anyOf": [{ "required": ["artifactPath"] }, { "required": ["url"] }] }
  }
}
