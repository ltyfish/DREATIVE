{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dreative.local/schemas/visual-critic.schema.json",
  "title": "Dreative Independent Visual Critic Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "reviewedAt", "inputArtifact", "contextIsolation", "reviewContext", "independentReading", "initialVerdict", "verdict", "strongestQualities", "findings", "baselineRegressions", "conceptFidelityFindings", "mobileFindings", "motionFindings", "requiredRevisionSet", "nonBlockingExperiments"],
  "properties": {
    "version": { "const": 1 }, "reviewedAt": { "type": "string", "format": "date-time" }, "inputArtifact": { "type": "string", "minLength": 1 },
    "contextIsolation": { "type": "object", "additionalProperties": false, "required": ["mode", "independentReadingRecordedAt", "limitation"], "properties": { "mode": { "enum": ["fresh-subagent", "fresh-context", "isolated-prompt", "best-effort"] }, "independentReadingRecordedAt": { "type": "string", "format": "date-time" }, "builderContextOpenedAt": { "type": "string", "format": "date-time" }, "limitation": { "type": "string", "minLength": 1 } } },
    "reviewContext": { "type": "object", "additionalProperties": false, "required": ["availableInputs", "missingInputs", "viewportsInspected", "pagesOrFlowsInspected", "motionInspected", "limitations"], "properties": { "availableInputs": { "type": "array", "items": { "type": "string" } }, "missingInputs": { "type": "array", "items": { "type": "string" } }, "viewportsInspected": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 } }, "pagesOrFlowsInspected": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }, "motionInspected": { "type": "boolean" }, "limitations": { "type": "array", "items": { "type": "string" } } } },
    "independentReading": { "type": "object", "additionalProperties": false, "required": ["perceivedConcept", "perceivedSignature", "perceivedBrandCharacter", "perceivedMotionRole"], "properties": { "perceivedConcept": { "$ref": "#/$defs/observation" }, "perceivedSignature": { "$ref": "#/$defs/observation" }, "perceivedBrandCharacter": { "$ref": "#/$defs/observation" }, "perceivedMotionRole": { "$ref": "#/$defs/observation" } } },
    "initialVerdict": { "$ref": "#/$defs/verdict" }, "verdict": { "$ref": "#/$defs/verdict" },
    "strongestQualities": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["location", "quality", "evidenceIds"], "properties": { "location": { "type": "string", "minLength": 8 }, "quality": { "type": "string", "minLength": 12 }, "evidenceIds": { "$ref": "#/$defs/evidenceIds" } } } },
    "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
    "baselineRegressions": { "$ref": "#/$defs/strings" }, "conceptFidelityFindings": { "$ref": "#/$defs/strings" }, "mobileFindings": { "$ref": "#/$defs/strings" }, "motionFindings": { "$ref": "#/$defs/strings" },
    "temporalAssessment": { "type": "object", "required": ["firstViewportResponsive", "developsBeyondEntrances", "crossSectionHandoffs", "signatureDevelops", "interactionPhysical", "primarilyStaticStack", "symbolicDowngrades", "evidenceIds"] },
    "routeAssessment": { "type": "object", "required": ["heroRemovedStillSatisfies", "fullRouteAuthored", "mediaDiverse", "ordinaryControlsSubstituteForExperience", "selectedTreatmentVerdicts", "peakVerdicts", "mechanismVerdicts", "assetIntegrity", "performanceRisk", "reducedMotionTranslation"] },
    "requiredRevisionSet": { "type": "array", "maxItems": 5, "uniqueItems": true, "items": { "type": "string", "minLength": 12 } },
    "nonBlockingExperiments": { "$ref": "#/$defs/strings" },
    "revision": { "type": "object", "additionalProperties": false, "required": ["iteration", "status", "resolutions", "recapturedEvidenceIds", "followUpReviewedAt"], "properties": { "iteration": { "const": 1 }, "status": { "const": "complete" }, "resolutions": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["findingId", "status", "evidenceIds", "reason"], "properties": { "findingId": { "type": "string", "minLength": 1 }, "status": { "enum": ["resolved", "partially-resolved", "unresolved", "intentionally-rejected"] }, "evidenceIds": { "$ref": "#/$defs/evidenceIds" }, "reason": { "type": "string", "minLength": 12 } } } }, "recapturedEvidenceIds": { "$ref": "#/$defs/evidenceIds" }, "followUpReviewedAt": { "type": "string", "format": "date-time" } } },
    "dogfood": { "type": "object", "additionalProperties": false, "required": ["falsePositives", "vagueFindings", "humanMisses", "styleConvergenceRisk", "complexityBias", "motionEvidenceRisk", "experimentsForRecipes"], "properties": { "falsePositives": { "$ref": "#/$defs/strings" }, "vagueFindings": { "$ref": "#/$defs/strings" }, "humanMisses": { "$ref": "#/$defs/strings" }, "styleConvergenceRisk": { "$ref": "#/$defs/strings" }, "complexityBias": { "$ref": "#/$defs/strings" }, "motionEvidenceRisk": { "$ref": "#/$defs/strings" }, "experimentsForRecipes": { "$ref": "#/$defs/strings" } } }
  },
  "$defs": {
    "verdict": { "enum": ["PASS", "PASS AFTER REVISION", "MAJOR REVISION REQUIRED", "INSUFFICIENT EVIDENCE"] },
    "observation": { "type": "string", "minLength": 12 }, "strings": { "type": "array", "items": { "type": "string", "minLength": 1 } }, "evidenceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "finding": { "type": "object", "additionalProperties": false, "required": ["id", "severity", "category", "location", "observedIssue", "whyItMatters", "correctionDirection", "evidenceIds", "blocksCompletion"], "properties": { "id": { "type": "string", "minLength": 1 }, "severity": { "enum": ["BLOCKER", "MAJOR", "MINOR", "EXPERIMENT"] }, "category": { "enum": ["authorship", "concept-fidelity", "hierarchy-composition", "mobile", "brand-specificity", "motion-interaction", "baseline-regression", "generic-template-risk", "usability"] }, "location": { "type": "string", "minLength": 8 }, "observedIssue": { "type": "string", "minLength": 20 }, "whyItMatters": { "type": "string", "minLength": 20 }, "correctionDirection": { "type": "string", "minLength": 20 }, "evidenceIds": { "$ref": "#/$defs/evidenceIds" }, "blocksCompletion": { "type": "boolean" } }
    }
  }
}
