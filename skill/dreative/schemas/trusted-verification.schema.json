{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dreative.local/schemas/trusted-verification.schema.json",
  "title": "Dreative Trusted Browser Verification v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verificationSchemaVersion", "runId", "nonce", "dreativeVersion", "browserRunner",
    "browserRunnerVersion", "browserName", "browserVersion", "startedAt", "finishedAt",
    "testedUrl", "approvedPlanHash", "sourceHash", "buildHash", "viewports",
    "interactionSequence", "artifacts", "captureManifest"
  ],
  "properties": {
    "verificationSchemaVersion": { "const": 5 },
    "runId": { "type": "string", "minLength": 12 },
    "nonce": { "type": "string", "minLength": 32 },
    "dreativeVersion": { "type": "string" },
    "browserRunner": { "const": "dreative-playwright-core" },
    "browserRunnerVersion": { "type": "string" },
    "browserName": { "type": "string" },
    "browserVersion": { "type": "string" },
    "startedAt": { "type": "string", "format": "date-time" },
    "finishedAt": { "type": "string", "format": "date-time" },
    "testedUrl": { "type": "string" },
    "approvedPlanHash": { "$ref": "#/$defs/hash" },
    "sourceHash": { "$ref": "#/$defs/hash" },
    "buildHash": { "$ref": "#/$defs/hash" },
    "viewports": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["name", "width", "height"] } },
    "interactionSequence": { "type": "array" },
    "artifacts": { "type": "array", "minItems": 3, "items": { "$ref": "#/$defs/artifact" } },
    "captureManifest": { "type": "string", "pattern": "\\.json$" }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "type", "path", "sha256", "bytes"],
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["screenshot", "recording", "trace", "capture-manifest"] },
        "path": { "type": "string" },
        "sha256": { "$ref": "#/$defs/hash" },
        "bytes": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
