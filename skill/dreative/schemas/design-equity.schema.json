{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dreative.local/schemas/design-equity.schema.json",
  "title": "Dreative Design Equity Baseline",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "capturedAt", "baselineQuality", "screenshots", "strongestVisualQualities", "weakestVisualQualities", "typographyCharacter", "colorMaterialCharacter", "compositionalStrengths", "hierarchyAndPacing", "signatureVisualElements", "animationInteractionInventory", "mobileStrengthsAndFailures", "distinctivePatterns", "genericOrDatedPatterns", "items"],
  "properties": {
    "version": { "const": 1 }, "capturedAt": { "type": "string", "format": "date-time" },
    "baselineQuality": { "enum": ["weak", "ordinary", "polished", "exceptional"] },
    "screenshots": { "type": "object", "additionalProperties": false, "required": ["desktop", "mobile"], "properties": { "desktop": { "$ref": "#/$defs/nonEmptyStrings" }, "mobile": { "$ref": "#/$defs/nonEmptyStrings" } } },
    "strongestVisualQualities": { "$ref": "#/$defs/nonEmptyStrings" }, "weakestVisualQualities": { "$ref": "#/$defs/nonEmptyStrings" },
    "typographyCharacter": { "type": "string", "minLength": 12 }, "colorMaterialCharacter": { "type": "string", "minLength": 12 },
    "compositionalStrengths": { "$ref": "#/$defs/nonEmptyStrings" }, "hierarchyAndPacing": { "type": "string", "minLength": 12 },
    "signatureVisualElements": { "$ref": "#/$defs/nonEmptyStrings" }, "animationInteractionInventory": { "$ref": "#/$defs/nonEmptyStrings" },
    "mobileStrengthsAndFailures": { "$ref": "#/$defs/nonEmptyStrings" }, "distinctivePatterns": { "$ref": "#/$defs/nonEmptyStrings" }, "genericOrDatedPatterns": { "$ref": "#/$defs/nonEmptyStrings" },
    "items": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["id", "quality", "decision", "rationale", "replacementOrEvolution", "successCriteria", "finalEvidenceIds"], "properties": { "id": { "type": "string", "minLength": 1 }, "quality": { "type": "string", "minLength": 12 }, "decision": { "enum": ["preserve", "transform", "surpass", "intentionally-remove"] }, "rationale": { "type": "string", "minLength": 12 }, "replacementOrEvolution": { "type": "string", "minLength": 12 }, "successCriteria": { "$ref": "#/$defs/nonEmptyStrings" }, "finalEvidenceIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }, "removalApprovalReference": { "type": "string", "minLength": 1 } } } }
  },
  "$defs": { "nonEmptyStrings": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } }
}
