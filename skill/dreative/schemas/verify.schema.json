{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dreative.local/schemas/verify.schema.json",
  "title": "Dreative Verification Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generatedAt", "runId", "buildIdentity", "evidence", "reconciliation"],
  "properties": {
    "version": { "const": 4 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "runId": { "type": "string", "minLength": 1 },
    "buildIdentity": { "type": "object", "required": ["algorithm", "runId", "dreativeVersion", "schemaVersion", "sourceTreeHash", "packageJsonHash", "lockfileHash", "publicAssetHash", "productionBuildHash", "framework", "packageManager", "buildCommand", "serverCommand", "testedOrigin", "testedUrl", "serverStartedAt", "verificationStartedAt", "verificationFinishedAt"] },
    "reconciliation": { "type": "object", "required": ["planned", "observed", "missing", "substituted", "extra"] },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "criterion", "kind", "criterionId", "pageId", "viewportClass", "status", "evidence", "proof"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "criterion": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["visual", "interaction", "motion", "media-transformation", "responsive", "preservation", "structural-depth", "design-equity", "concept-fidelity", "perceptual-comparison", "visual-regression"] },
          "criterionId": { "type": "string", "minLength": 1 },
          "pageId": { "type": "string", "minLength": 1 },
          "sectionId": { "type": "string", "minLength": 1 },
          "viewportClass": { "enum": ["desktop", "mobile", "narrow-mobile", "non-visual"] },
          "mobileChecks": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["no-horizontal-overflow", "no-clipped-content", "fixed-elements-clear-content", "safe-area-spacing", "primary-task-discoverable", "primary-action-reachable", "touch-targets", "software-keyboard-usable", "no-hover-only", "intentional-mobile-composition", "mobile-content-order", "motion-media-translated", "no-decorative-task-blocker"] } },
          "status": { "enum": ["pass", "fail", "not-applicable"] },
          "evidence": { "type": "string", "minLength": 1 },
          "timelineState": {
            "enum": ["initial", "early", "mid-transition", "final", "handoff", "pinned-midpoint", "pinned-exit", "reverse-interaction", "mobile", "reduced-motion"]
          },
          "motionMomentId": { "type": "string", "minLength": 1 },
          "mediaTransformationId": { "type": "string", "minLength": 1 },
          "verificationRunId": { "type": "string", "minLength": 1 },
          "buildIdentityHash": { "type": "string", "minLength": 64 },
          "proof": {
            "type": "object",
            "additionalProperties": false,
            "required": ["timestamp"],
            "properties": {
              "timestamp": { "type": "string", "format": "date-time" },
              "artifactPath": { "type": "string", "minLength": 1 },
              "viewport": {
                "type": "object",
                "additionalProperties": false,
                "required": ["width", "height"],
                "properties": {
                  "width": { "type": "number", "exclusiveMinimum": 0 },
                  "height": { "type": "number", "exclusiveMinimum": 0 },
                  "dpr": { "type": "number", "exclusiveMinimum": 0 }
                }
              },
              "command": { "type": "string", "minLength": 1 },
              "exitCode": { "type": "integer" },
              "consoleErrorCount": { "type": "integer", "minimum": 0 },
              "testedUrl": { "type": "string", "minLength": 1 },
              "averageFps": { "type": "number", "exclusiveMinimum": 0 },
              "maxFrameTimeMs": { "type": "number", "minimum": 0 },
              "worstFrameTimeMs": { "type": "number", "minimum": 0 },
              "longTaskCount": { "type": "integer", "minimum": 0 },
              "transferredMediaBytes": { "type": "integer", "minimum": 0 },
              "heavyChunkBytes": { "type": "integer", "minimum": 0 },
              "playwrightTestId": { "type": "string", "minLength": 1 }
              ,"recordingPath": { "type": "string", "minLength": 1 }
              ,"tracePath": { "type": "string", "minLength": 1 }
              ,"captureManifestPath": { "type": "string", "minLength": 1 }
              ,"startTimestamp": { "type": "string", "format": "date-time" }
              ,"endTimestamp": { "type": "string", "format": "date-time" }
              ,"controlledProgress": { "type": ["number", "string"] }
              ,"triggerValue": { "type": "string", "minLength": 1 }
              ,"observedProperties": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["property", "expected", "observed"], "properties": { "property": { "type": "string", "minLength": 1 }, "expected": { "type": "string", "minLength": 1 }, "observed": { "type": "string", "minLength": 1 } } } }
              ,"pixelDifferenceFromPrevious": { "type": "number", "minimum": 0, "maximum": 1 }
              ,"structuralDifferenceFromPrevious": { "type": "number", "minimum": 0, "maximum": 1 }
              ,"compositionStateHash": { "type": "string", "minLength": 16 }
              ,"frameIndex": { "type": "integer", "minimum": 0 }
              ,"mediaCurrentTime": { "type": "number", "minimum": 0 }
              ,"cameraState": { "type": "object", "additionalProperties": false, "required": ["position", "rotation", "fov"], "properties": { "position": { "$ref": "#/$defs/vector3" }, "rotation": { "$ref": "#/$defs/vector3" }, "fov": { "type": "number", "exclusiveMinimum": 0 } } }
              ,"shaderUniforms": { "type": "object", "additionalProperties": { "type": "number" } }
              ,"particleState": { "type": "object", "additionalProperties": false, "required": ["activeCount", "spread", "reassembly"], "properties": { "activeCount": { "type": "integer", "minimum": 0 }, "spread": { "type": "number" }, "reassembly": { "type": "number", "minimum": 0, "maximum": 1 } } }
              ,"maskProgress": { "type": "number", "minimum": 0, "maximum": 1 }
              ,"expectedState": { "type": "string", "minLength": 12 }
              ,"observedState": { "type": "string", "minLength": 12 }
              ,"reversePlayResult": { "type": "string", "minLength": 12 }
              ,"mobileResult": { "type": "string", "minLength": 12 }
              ,"reducedMotionResult": { "type": "string", "minLength": 12 }
              ,"artifactHash": { "type": "string", "minLength": 64 }
              ,"captureSource": { "enum": ["browser", "playwright", "devtools", "runtime-instrumentation"] }
            },
            "anyOf": [
              { "required": ["artifactPath"] },
              { "required": ["command", "exitCode"] },
              { "required": ["consoleErrorCount"] },
              { "required": ["testedUrl"] },
              { "required": ["averageFps"] },
              { "required": ["maxFrameTimeMs"] },
              { "required": ["playwrightTestId"] }
              ,{ "required": ["recordingPath", "startTimestamp", "endTimestamp"] }
              ,{ "required": ["tracePath", "startTimestamp", "endTimestamp"] }
              ,{ "required": ["controlledProgress", "observedProperties", "expectedState", "observedState"], "anyOf": [
                { "required": ["artifactPath"] },
                { "required": ["command", "exitCode"] },
                { "required": ["playwrightTestId"] },
                { "required": ["tracePath"] },
                { "required": ["captureManifestPath"] }
              ] }
            ]
          }
        }
      }
    },
    "staticFeelingReview": {
      "type": "object", "additionalProperties": false,
      "required": ["developsWithoutEntrances", "firstViewportMeaningfulResponse", "beyondOpacityAndPosition", "crossSectionInfluence", "signatureDevelops", "brandSpecificMotion", "memorableSequence", "primarilyStaticStack"],
      "properties": { "developsWithoutEntrances": { "$ref": "#/$defs/passingStaticAnswer" }, "firstViewportMeaningfulResponse": { "$ref": "#/$defs/passingStaticAnswer" }, "beyondOpacityAndPosition": { "$ref": "#/$defs/passingStaticAnswer" }, "crossSectionInfluence": { "$ref": "#/$defs/passingStaticAnswer" }, "signatureDevelops": { "$ref": "#/$defs/passingStaticAnswer" }, "brandSpecificMotion": { "$ref": "#/$defs/passingStaticAnswer" }, "memorableSequence": { "$ref": "#/$defs/passingStaticAnswer" }, "primarilyStaticStack": { "$ref": "#/$defs/failingStaticAnswer" } }
    },
    "perceptualComparison": {
      "type": "object", "additionalProperties": false,
      "required": ["baselineEvidenceIds", "finalEvidenceIds", "observations", "weaknesses", "refinementEvidenceIds", "equityDecisionEvidence", "signatureEvidenceIds"],
      "properties": {
        "baselineEvidenceIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "finalEvidenceIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "observations": { "type": "object", "additionalProperties": false, "required": ["distinctiveness", "hierarchy", "typography", "colorMaterialIdentity", "compositionalAuthorship", "brandSpecificity", "motionInteractionQuality", "responsiveQuality", "retainedOrSurpassedStrengths", "conceptFidelity", "genericTemplateRisk"], "properties": { "distinctiveness": { "type": "string", "minLength": 20 }, "hierarchy": { "type": "string", "minLength": 20 }, "typography": { "type": "string", "minLength": 20 }, "colorMaterialIdentity": { "type": "string", "minLength": 20 }, "compositionalAuthorship": { "type": "string", "minLength": 20 }, "brandSpecificity": { "type": "string", "minLength": 20 }, "motionInteractionQuality": { "type": "string", "minLength": 20 }, "responsiveQuality": { "type": "string", "minLength": 20 }, "retainedOrSurpassedStrengths": { "type": "string", "minLength": 20 }, "conceptFidelity": { "type": "string", "minLength": 20 }, "genericTemplateRisk": { "type": "string", "minLength": 20 } } },
        "weaknesses": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "refinementEvidenceIds": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "explicitApprovalReference": { "type": "string", "minLength": 1 },
        "equityDecisionEvidence": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["equityId", "evidenceIds"], "properties": { "equityId": { "type": "string", "minLength": 1 }, "evidenceIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } } },
        "signatureEvidenceIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "refinement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inspectedAt", "findings", "changes", "evidenceIds"],
      "properties": {
        "inspectedAt": { "type": "string", "format": "date-time" },
        "findings": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "changes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "evidenceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    }
  },
  "$defs": {
    "vector3": { "type": "array", "prefixItems": [{ "type": "number" }, { "type": "number" }, { "type": "number" }], "minItems": 3, "maxItems": 3 },
    "staticAnswer": { "type": "object", "additionalProperties": false, "required": ["answer", "evidenceIds", "observation"], "properties": { "answer": { "type": "boolean" }, "evidenceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "observation": { "type": "string", "minLength": 20 } } },
    "passingStaticAnswer": { "allOf": [{ "$ref": "#/$defs/staticAnswer" }, { "properties": { "answer": { "const": true } } }] },
    "failingStaticAnswer": { "allOf": [{ "$ref": "#/$defs/staticAnswer" }, { "properties": { "answer": { "const": false } } }] }
  }
}
