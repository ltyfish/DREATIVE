{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dreative.local/schemas/plan.schema.json",
  "title": "Dreative Canonical Plan v9",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "contract", "approval", "execution"],
  "properties": {
    "version": { "const": 9 },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target", "scope", "creativeSources", "workflow", "transformationDepth", "selectedTreatments",
        "treatmentDecisions", "allTreatmentsExplicit", "allTreatmentsConfirmed", "treatmentAllocation", "continuityOwner",
        "preservationRequirements", "selectedConcept", "blueprint", "experienceDistribution",
        "experimentalPeaks", "prototypeContracts", "assetStrategy", "motionAndMediaStrategy",
        "mobileTranslation", "functionalTruthRequirements", "performanceBudget", "acceptanceCriteria",
        "mechanismFallbacks", "conceptExemptions", "changeRequests", "subjectInventory"
      ],
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "sourceBaselineHashAtCreation": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "repositoryBaseline": { "type": "object" },
        "projectDefinition": {
          "type": "object", "additionalProperties": false,
          "required": ["purpose", "targetAudience", "primaryUserJourney", "routes", "requiredFunctionality", "extractedRequirements", "nonGoals", "preservedContentOrFunctionality"],
          "properties": {
            "purpose": { "type": "string" }, "targetAudience": { "type": "string" }, "primaryUserJourney": { "type": "string" },
            "routes": { "$ref": "#/$defs/nonEmptyStrings" }, "requiredFunctionality": { "$ref": "#/$defs/nonEmptyStrings" },
            "extractedRequirements": { "$ref": "#/$defs/nonEmptyStrings" }, "nonGoals": { "$ref": "#/$defs/strings" },
            "preservedContentOrFunctionality": { "$ref": "#/$defs/strings" }
          }
        },
        "creativeDirection": {
          "type": "object", "additionalProperties": false,
          "required": ["selectedConcept", "fitRationale", "nonGenericQualities", "visualLanguage", "compositionStrategy", "typographyStrategy", "mediaStrategy", "motionInteractionPhilosophy", "experienceProgression"],
          "properties": {
            "selectedConcept": { "type": "string" }, "fitRationale": { "type": "string" }, "nonGenericQualities": { "type": "string" },
            "visualLanguage": { "type": "string" }, "compositionStrategy": { "type": "string" }, "typographyStrategy": { "type": "string" },
            "mediaStrategy": { "type": "string" }, "motionInteractionPhilosophy": { "type": "string" }, "experienceProgression": { "type": "string" }
          }
        },
        "sectionContracts": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/sectionContract" } },
        "continuityContract": {
          "type": "object", "additionalProperties": false,
          "required": ["owner", "medium", "sourceOwner", "sectionChanges", "persistenceVerification", "breakConditions"],
          "properties": {
            "owner": { "type": "string" }, "medium": { "enum": ["DOM", "SVG", "Canvas", "WebGL", "media", "hybrid"] },
            "sourceOwner": { "type": "string" }, "sectionChanges": { "type": "string" },
            "persistenceVerification": { "type": "string" }, "breakConditions": { "type": "string" }
          }
        },
        "mechanismContracts": { "type": "array", "items": { "$ref": "#/$defs/mechanismContract" } },
        "requirementTraceability": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/requirementTrace" } },
        "subjectInventory": { "type": "array", "items": { "$ref": "#/$defs/subject" } },
        "packagePlan": { "type": "object" },
        "verificationPlan": { "type": "object" },
        "target": { "type": "object" },
        "scope": { "type": "object" },
        "creativeSources": {
          "type": "object",
          "properties": {
            "generatedImages": {}, "sourcedImages": {}, "generatedVideo": {}, "sourcedVideo": {}, "threeDAssets": {}
          }
        },
        "capabilityPreflight": { "$ref": "#/$defs/capabilityPreflight" },
        "workflow": { "$ref": "#/$defs/workflow" },
        "transformationDepth": { "enum": ["restyle", "relayout", "restructure", "reimagine"] },
        "selectedTreatments": { "$ref": "#/$defs/treatments" },
        "treatmentDecisions": {
          "type": "array", "minItems": 10, "maxItems": 10,
          "items": {
            "type": "object", "required": ["treatment", "state", "explicitlyDecided", "reason"],
            "properties": {
              "treatment": { "$ref": "#/$defs/treatment" },
              "state": { "enum": ["foundational", "recommended", "selected", "declined", "not-applicable"] },
              "explicitlyDecided": { "type": "boolean" }, "reason": { "type": "string" }
            }
          }
        },
        "allTreatmentsExplicit": { "type": "boolean" },
        "allTreatmentsConfirmed": { "type": "boolean" },
        "continuityOwner": { "enum": ["immersive", "cinematic", "motion", "none"] },
        "treatmentAllocation": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["treatment", "priority", "locations", "contribution", "dependencies", "acceptance", "routeRole"],
            "properties": {
              "treatment": { "$ref": "#/$defs/treatment" },
              "priority": { "enum": ["primary", "supporting", "foundation"] },
              "locations": { "$ref": "#/$defs/strings" },
              "contribution": { "type": "string" },
              "dependencies": { "$ref": "#/$defs/treatments" },
              "acceptance": { "$ref": "#/$defs/strings" },
              "routeRole": { "enum": ["peak", "connective-tissue", "foundation"] },
              "mechanismIds": { "$ref": "#/$defs/nonEmptyStrings" },
              "mobileObligation": { "type": "string" },
              "reducedMotionObligation": { "type": "string" },
              "failureCriteria": { "$ref": "#/$defs/nonEmptyStrings" }
            }
          }
        },
        "preservationRequirements": { "$ref": "#/$defs/strings" },
        "selectedConcept": { "type": "string" },
        "blueprint": { "type": "array", "items": { "type": "object" } },
        "experienceArc": { "type": "object" },
        "experienceDistribution": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pageId", "sectionId", "order", "role", "continuityContribution"],
            "properties": {
              "pageId": { "type": "string" },
              "sectionId": { "type": "string" },
              "order": { "type": "integer", "minimum": 0 },
              "role": { "enum": ["peak", "transformation", "preparation", "echo", "rest", "resolution", "functional-utility"] },
              "continuityContribution": { "type": "string" },
              "peakId": { "type": "string" }
            }
          }
        },
        "experimentalPeaks": { "type": "array", "minItems": 0, "maxItems": 3, "items": { "$ref": "#/$defs/experimentalPeak" } },
        "prototypeContracts": { "type": "array", "items": { "$ref": "#/$defs/prototype" } },
        "assetStrategy": { "type": "array", "items": { "$ref": "#/$defs/asset" } },
        "motionAndMediaStrategy": { "type": "string" },
        "mobileTranslation": { "type": "string" },
        "functionalTruthRequirements": { "$ref": "#/$defs/strings" },
        "performanceBudget": { "$ref": "#/$defs/strings" },
        "acceptanceCriteria": { "$ref": "#/$defs/strings" },
        "mechanismFallbacks": { "type": "array", "items": { "$ref": "#/$defs/mechanism" } },
        "videoDeliveryDecision": {
          "type": "object", "additionalProperties": false,
          "required": ["decision", "reason", "processingRoute", "mobileStrategy", "reducedMotionStrategy"],
          "properties": {
            "decision": { "enum": ["video", "frame-sequence-or-prerendered-motion", "approved-exemption"] },
            "reason": { "type": "string", "minLength": 20 }, "processingRoute": { "type": "string", "minLength": 12 },
            "mobileStrategy": { "type": "string", "minLength": 12 }, "reducedMotionStrategy": { "type": "string", "minLength": 12 },
            "approvalReference": { "type": "string", "minLength": 1 }
          }
        },
        "conceptExemptions": { "type": "array", "items": { "type": "object" } },
        "changeRequests": { "type": "array", "items": { "type": "object" } }
      }
    },
    "approval": {
      "type": "object",
      "properties": {
        "contractHash": { "type": ["string", "null"] },
        "approvalMode": { "enum": ["human", "pre-authorized-dogfood"] },
        "approvalOrigin": { "enum": ["interactive-user", "explicit-preauthorization"] },
        "provenance": { "$ref": "#/$defs/provenance" },
        "approvedSourceBaselineHash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "execution": {
      "type": "object",
      "properties": {
        "runtimeObservations": { "type": "array", "items": { "$ref": "#/$defs/runtimeObservation" } },
        "signatureMediaPackages": { "type": "array", "items": { "$ref": "#/$defs/signatureMediaPackage" } },
        "capabilityActions": { "type": "array", "items": { "$ref": "#/$defs/capabilityAction" } },
        "firstMaterialSourceChangeAt": { "type": ["string", "null"], "format": "date-time" },
        "planSummaryShownAt": { "type": ["string", "null"], "format": "date-time" },
        "planReviewContractHash": { "type": ["string", "null"] },
        "prototypeGate": { "type": "object" },
        "evidenceState": { "type": "object" }
      }
    }
  },
  "$defs": {
    "strings": { "type": "array", "items": { "type": "string" } },
    "nonEmptyStrings": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "sectionContract": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "route", "narrativePurpose", "mainUserAction", "visualRole", "mediaRole", "interactionRole", "entryState", "activeState", "resolvedState", "handoff", "mobileBehavior", "reducedMotionBehavior", "fallbackBehavior", "verificationRequirement"],
      "properties": {
        "id": { "type": "string" }, "route": { "type": "string" }, "narrativePurpose": { "type": "string" },
        "mainUserAction": { "type": "string" }, "visualRole": { "type": "string" }, "mediaRole": { "type": "string" },
        "interactionRole": { "type": "string" }, "entryState": { "type": "string" }, "activeState": { "type": "string" },
        "resolvedState": { "type": "string" }, "handoff": { "type": "string" }, "mobileBehavior": { "type": "string" },
        "reducedMotionBehavior": { "type": "string" }, "fallbackBehavior": { "type": "string" }, "verificationRequirement": { "type": "string" }
      }
    },
    "mechanismContract": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "catalogueSourceOrCustomRationale", "routeOrSection", "inputDriver", "startState", "activeState", "endState", "reverseBehavior", "rapidInputBehavior", "refreshAtProgressBehavior", "mobileBehavior", "reducedMotionBehavior", "dependency", "performanceExpectation", "approvedFallback", "fallbackTrigger", "requiredCaptureStates", "successCriteria", "failureCriteria"],
      "properties": {
        "id": { "type": "string" }, "catalogueSourceOrCustomRationale": { "type": "string" }, "routeOrSection": { "type": "string" },
        "inputDriver": { "enum": ["scroll-progress", "velocity", "pointer", "drag", "hold", "time", "audio", "route", "keyboard", "click", "media-progress"] },
        "startState": { "type": "string" }, "activeState": { "type": "string" }, "endState": { "type": "string" },
        "reverseBehavior": { "type": "string" }, "rapidInputBehavior": { "type": "string" }, "refreshAtProgressBehavior": { "type": "string" },
        "mobileBehavior": { "type": "string" }, "reducedMotionBehavior": { "type": "string" }, "dependency": { "type": "string" },
        "performanceExpectation": { "type": "string" }, "approvedFallback": { "type": "string" }, "fallbackTrigger": { "type": "string" },
        "requiredCaptureStates": { "$ref": "#/$defs/nonEmptyStrings" }, "successCriteria": { "$ref": "#/$defs/nonEmptyStrings" },
        "failureCriteria": { "$ref": "#/$defs/nonEmptyStrings" },
        "sectionId": { "type": "string" }, "subjectIds": { "$ref": "#/$defs/nonEmptyStrings" },
        "treatments": { "$ref": "#/$defs/treatments" }, "runtimeOwner": { "type": "string" }, "trigger": { "type": "string" },
        "actions": { "type": "array", "items": { "$ref": "#/$defs/action" } },
        "selectors": { "$ref": "#/$defs/nonEmptyStrings" }, "assertions": { "type": "array", "items": { "$ref": "#/$defs/assertion" } },
        "expectedResults": { "$ref": "#/$defs/nonEmptyStrings" }, "mobileTransformation": { "type": "string" },
        "reducedMotionTransformation": { "type": "string" }, "fallbackId": { "type": "string" }
      }
    },
    "requirementTrace": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "source", "wording", "plannedImplementation", "routeOrComponent", "browserTest", "evidenceId", "status"],
      "properties": {
        "id": { "type": "string" }, "source": { "type": "string" }, "wording": { "type": "string" },
        "plannedImplementation": { "type": "string" }, "routeOrComponent": { "type": "string" },
        "browserTest": { "type": "string" }, "evidenceId": { "type": "string" },
        "status": { "enum": ["planned", "implemented", "verified", "failed", "removed"] },
        "actions": { "type": "array", "items": { "$ref": "#/$defs/action" } },
        "assertions": { "type": "array", "items": { "$ref": "#/$defs/assertion" } }
      }
    },
    "action": {
      "type": "object", "additionalProperties": false, "required": ["action"],
      "properties": {
        "action": { "enum": ["goto", "click", "fill", "press", "scroll", "reverse-scroll", "reload", "wait"] },
        "selector": { "type": "string" }, "value": { "type": "string" }
      }
    },
    "assertion": {
      "type": "object", "additionalProperties": false, "required": ["type"],
      "properties": {
        "type": { "enum": ["visible", "hidden", "text-contains", "text-equals", "url-contains", "url-equals", "attribute-equals", "input-value", "selected", "dialog-open", "dialog-closed", "form-invalid", "form-valid", "network-request", "network-success", "download", "canvas-changed", "media-changed", "mechanism-state"] },
        "selector": { "type": "string" }, "attribute": { "type": "string" }, "expected": {}, "mechanismId": { "type": "string" }
      }
    },
    "subject": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "type", "recognizableAs", "narrativeRole", "sectionIds", "sourceMethod", "assetIds", "rightsRequirements", "recurring", "mobileRepresentation", "reducedMotionRepresentation", "fallbackClassification"],
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["primary-subject", "hero-object", "continuity-object", "prop", "component", "environment", "material", "texture", "still-composition", "video", "frame-sequence", "spatial"] },
        "recognizableAs": { "type": "string" }, "narrativeRole": { "type": "string" }, "sectionIds": { "$ref": "#/$defs/nonEmptyStrings" },
        "sourceMethod": { "enum": ["supplied", "external-sourced", "generated", "procedural"] }, "assetIds": { "$ref": "#/$defs/strings" },
        "rightsRequirements": { "$ref": "#/$defs/nonEmptyStrings" }, "recurring": { "type": "boolean" }, "continuityPurpose": { "type": "string" },
        "mobileRepresentation": { "type": "string" }, "reducedMotionRepresentation": { "type": "string" },
        "fallbackClassification": { "enum": ["model", "spatial-cutout", "layered-billboard", "pre-rendered-angles", "frame-sequence", "webgl-media-plane", "static-image"] }
      }
    },
    "provenance": {
      "type": "object", "additionalProperties": false,
      "required": ["authority", "sourceType", "assuranceLevel", "scope", "recordedAt"],
      "properties": {
        "authority": { "enum": ["host-attested-user", "prompt-preauthorized", "user-origin-unverified", "internal", "none"] },
        "sourceType": { "enum": ["host-event", "signed-record", "prompt-file", "cli", "internal"] },
        "sourceId": { "type": "string" }, "contentHash": { "type": "string" }, "filePath": { "type": "string" },
        "attestationProvider": { "type": "string" }, "assuranceLevel": { "enum": ["local", "host-attested", "externally-attested"] },
        "scope": { "$ref": "#/$defs/nonEmptyStrings" }, "recordedAt": { "type": "string" }, "contentRecordedBeforePlanning": { "type": "boolean" }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ambition", "execution", "prototype", "purpose"],
      "properties": {
        "ambition": { "enum": ["standard", "expressive", "award", "experimental"] },
        "execution": { "enum": ["fast", "lean", "full-audit"] },
        "prototype": { "enum": ["skip", "auto", "required"] },
        "purpose": { "enum": ["project-delivery", "production-certification", "dreative-dogfood"] }
      }
    },
    "treatment": { "enum": ["ux", "mobile", "refined", "motion", "interaction", "media", "3d", "immersive", "cinematic", "experimental"] },
    "treatments": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/treatment" } },
    "capabilityPreflight": {
      "type": "object",
      "required": ["capturedAt", "installedCapabilities", "creativeCapabilities"],
      "properties": {
        "capturedAt": { "type": "string" },
        "installedCapabilities": { "$ref": "#/$defs/strings" },
        "creativeCapabilities": {
          "type": "array",
          "items": {
            "type": "object",
              "required": ["id", "category", "permission", "status", "detectionSource", "confidence", "verificationEvidence", "limitation", "permittedSubstitutes"],
            "properties": {
              "id": { "type": "string" },
              "category": { "enum": ["creative-authoring", "sourcing", "runtime-rendering", "processing", "verification"] },
              "permission": { "enum": ["allowed", "denied", "unresolved", "not-applicable"] },
              "status": { "enum": ["available", "available-after-package-install", "available-through-confirmed-tool", "available-through-supplied-asset", "expected-browser-api-unverified", "permitted-but-tool-unverified", "permission-unresolved", "permission-denied", "unavailable", "runtime-verification-failed"] },
              "detectionSource": { "type": "string" }, "confidence": { "enum": ["verified", "detected", "expected", "unverified"] },
              "verificationEvidence": { "$ref": "#/$defs/strings" }, "limitation": { "type": "string" }, "permittedSubstitutes": { "$ref": "#/$defs/strings" }
            }
          }
        }
      }
    },
    "experimentalPeak": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "chapter", "mechanismFamily", "plannedBehaviour", "startState", "activeState", "resolution", "inputRelationship", "mobileStrategy", "reducedMotionStrategy", "fallbackState", "prototypeRiskFamily", "acceptance"],
      "properties": {
        "id": { "type": "string" }, "chapter": { "type": "string" }, "mechanismFamily": { "type": "string" },
        "plannedBehaviour": { "type": "string" }, "startState": { "type": "string" }, "activeState": { "type": "string" },
        "resolution": { "type": "string" }, "inputRelationship": { "type": "string" }, "mobileStrategy": { "type": "string" },
        "reducedMotionStrategy": { "type": "string" }, "fallbackState": { "type": "string" }, "prototypeRiskFamily": { "type": "string" },
        "acceptance": { "$ref": "#/$defs/strings" }
      }
    },
    "prototype": {
      "type": "object",
      "required": ["id", "riskFamily", "mechanismId", "required", "uncertainty", "acceptanceConditions", "maximumScope", "failureImplications"],
      "properties": {
        "id": { "type": "string" }, "riskFamily": { "type": "string" }, "mechanismId": { "type": "string" },
        "required": { "type": "boolean" }, "uncertainty": { "type": "string" }, "acceptanceConditions": { "$ref": "#/$defs/strings" },
        "maximumScope": { "type": "string" }, "failureImplications": { "type": "string" }
      }
    },
    "asset": {
      "type": "object",
      "required": ["id", "intendedRole", "requiredSubjectAndComposition", "priority", "sourcingPolicy", "generationPolicy", "generationRationale", "classification", "rightsRequirements", "expectedFormatsAndVariants", "requiredLocations", "reusePolicy", "suitableExternalMediaCouldExist"],
      "properties": {
        "id": { "type": "string" }, "intendedRole": { "type": "string" }, "requiredSubjectAndComposition": { "type": "string" },
        "priority": { "enum": ["user-supplied", "external-sourced", "generated", "procedural"] },
        "sourcingPolicy": { "enum": ["external-first", "generation-first-exemption", "supplied-only", "procedural"] },
        "generationPolicy": { "enum": ["allowed-with-advantage", "not-allowed", "required-bespoke"] }, "generationRationale": { "type": "string" },
        "classification": { "enum": ["model", "spatial-cutout", "layered-billboard", "pre-rendered-angles", "frame-sequence", "webgl-media-plane", "static-image"] },
        "rightsRequirements": { "$ref": "#/$defs/strings" }, "expectedFormatsAndVariants": { "$ref": "#/$defs/strings" },
        "requiredLocations": { "$ref": "#/$defs/strings" }, "reusePolicy": { "type": "string" },
        "suitableExternalMediaCouldExist": { "type": "boolean" }, "sizeBudgetBytes": { "type": "integer", "minimum": 0 }
      }
    },
    "mechanism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "location", "primaryImplementation", "primaryAcceptance", "fallbackImplementation", "fallbackTrigger", "triggerEvidenceRequired", "userReapprovalRequired", "allowedSubstitutions", "riskFamily", "prototypePolicy"],
      "properties": {
        "id": { "type": "string" },
        "location": { "type": "string" },
        "primaryImplementation": { "type": "string" },
        "primaryAcceptance": { "$ref": "#/$defs/strings" },
        "fallbackImplementation": { "type": "string" },
        "fallbackTrigger": { "type": "string" },
        "triggerEvidenceRequired": { "$ref": "#/$defs/strings" },
        "userReapprovalRequired": { "type": "boolean" },
        "allowedSubstitutions": { "$ref": "#/$defs/strings" },
        "riskFamily": { "type": "string" },
        "prototypePolicy": { "type": "string" }
      }
    },
    "runtimeObservation": {
      "type": "object",
      "required": ["id", "sectionId", "continuityOwner", "implementationFile", "componentOrSelector", "mechanismFamily", "spatialClassification", "sourceAssets", "inputDrivers", "samples", "postHero", "assetTransformsInternally", "pinnedOrControlledComposition", "nonObviousBehavior", "neutralStylingStillSpecial", "mobile", "reducedMotion", "reverse", "performance", "recordingIds"],
      "properties": {
        "id": { "type": "string" },
        "sectionId": { "type": "string" },
        "continuityOwner": { "type": "string" },
        "implementationFile": { "type": "string" },
        "componentOrSelector": { "type": "string" },
        "mechanismFamily": { "enum": ["frame-sequence", "video-scrub", "shader-media", "particle-reconstruction", "tile-slice-fold", "depth-parallax", "camera-travel", "spatial-field", "shared-element-handoff", "kinetic-type", "hold-charge-release", "layout-transition", "ordinary-control", "rigid-media-plane", "decorative-motion"] },
        "spatialClassification": { "enum": ["model", "spatial-cutout", "layered-billboard", "pre-rendered-angles", "frame-sequence", "webgl-media-plane", "static-image"] },
        "sourceAssets": { "$ref": "#/$defs/strings" },
        "inputDrivers": { "type": "array", "items": { "enum": ["scroll-progress", "velocity", "pointer", "drag", "hold", "time", "audio", "route", "keyboard"] } },
        "samples": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "type": "object",
            "required": ["progress", "captureId", "artifactHash", "compositionStateHash", "observedProperties", "channels"],
            "properties": {
              "progress": { "enum": [0, 25, 50, 75, 100] },
              "captureId": { "type": "string" },
              "artifactHash": { "type": "string" },
              "compositionStateHash": { "type": "string" },
              "observedProperties": { "type": "array" },
              "channels": { "type": "array" }
            }
          }
        },
        "postHero": { "type": "boolean" },
        "assetTransformsInternally": { "type": "boolean" },
        "pinnedOrControlledComposition": { "type": "boolean" },
        "nonObviousBehavior": { "type": "boolean" },
        "neutralStylingStillSpecial": { "type": "boolean" },
        "mobile": { "type": "object" },
        "reducedMotion": { "type": "object" },
        "reverse": { "type": "object" },
        "performance": { "type": "object" },
        "recordingIds": { "$ref": "#/$defs/strings" }
      }
    },
    "signatureMediaPackage": {
      "type": "object",
      "required": ["id", "sourceAssets", "derivatives", "implementationConsumers", "optimization", "temporalEvidenceIds", "mobileVariant", "reducedMotionAsset"],
      "properties": {
        "id": { "type": "string" },
        "sourceAssets": { "$ref": "#/$defs/strings" },
        "derivatives": { "type": "array", "minItems": 1 },
        "implementationConsumers": { "$ref": "#/$defs/strings" },
