{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dreative.local/schemas/plan.schema.json",
  "title": "Dreative Canonical Plan v7",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "contract", "approval", "execution"],
  "properties": {
    "version": { "const": 7 },
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target", "scope", "creativeSources", "workflow", "transformationDepth", "selectedTreatments",
        "allTreatmentsExplicit", "allTreatmentsConfirmed", "treatmentAllocation",
        "preservationRequirements", "selectedConcept", "blueprint", "motionAndMediaStrategy",
        "mobileTranslation", "functionalTruthRequirements", "performanceBudget",
        "acceptanceCriteria", "mechanismFallbacks", "conceptExemptions", "changeRequests"
      ],
      "properties": {
        "target": { "$ref": "#/$defs/target" },
        "scope": { "type": "object" },
        "creativeSources": { "$ref": "#/$defs/creativeSources" },
        "workflow": { "$ref": "#/$defs/workflow" },
        "transformationDepth": { "enum": ["restyle", "relayout", "restructure", "reimagine"] },
        "selectedTreatments": { "$ref": "#/$defs/treatments" },
        "allTreatmentsExplicit": { "type": "boolean" },
        "allTreatmentsConfirmed": { "type": "boolean" },
        "treatmentAllocation": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["treatment", "priority", "locations", "contribution", "dependencies", "acceptance"],
            "properties": {
              "treatment": { "$ref": "#/$defs/treatment" },
              "priority": { "enum": ["primary", "supporting", "foundation"] },
              "locations": { "type": "array", "items": { "type": "string" } },
              "contribution": { "type": "string" },
              "dependencies": { "$ref": "#/$defs/treatments" },
              "acceptance": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "preservationRequirements": { "type": "array", "items": { "type": "string" } },
        "selectedConcept": { "type": "string" },
        "blueprint": { "type": "array", "items": { "type": "object" } },
        "experienceArc": { "$ref": "#/$defs/experienceArc" },
        "motionAndMediaStrategy": { "type": "string" },
        "mobileTranslation": { "type": "string" },
        "functionalTruthRequirements": { "type": "array", "items": { "type": "string" } },
        "performanceBudget": { "type": "array", "items": { "type": "string" } },
        "acceptanceCriteria": { "type": "array", "items": { "type": "string" } },
        "mechanismFallbacks": { "type": "array", "items": { "type": "object" } },
        "conceptExemptions": { "type": "array", "items": { "type": "object" } },
        "changeRequests": { "type": "array", "items": { "type": "object" } }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "revision", "contractHash", "approvedAt", "approvedBy", "decisionHistory"],
      "properties": {
        "status": { "enum": ["pending", "approved", "invalidated"] },
        "revision": { "type": "integer", "minimum": 0 },
        "contractHash": { "type": ["string", "null"] },
        "approvedAt": { "type": ["string", "null"] },
        "approvedBy": { "type": ["string", "null"] },
        "decisionHistory": { "type": "array", "items": { "type": "object" } }
      }
    },
    "execution": { "type": "object" }
  },
  "$defs": {
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ambition", "execution", "prototype", "purpose"],
      "properties": {
        "ambition": { "enum": ["standard", "expressive", "award", "experimental"] },
        "execution": { "enum": ["fast", "lean", "full-audit"] },
        "prototype": { "enum": ["skip", "auto", "required"] },
        "purpose": { "enum": ["project-delivery", "production-certification", "dreative-dogfood"] }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repoRoot", "previewUrl", "previewCommand", "routeScope", "baselineUrls", "packageManager", "buildCommand", "testCommand", "framework", "deploymentTarget", "devicePriorities"],
      "properties": {
        "repoRoot": { "type": "string", "minLength": 1 },
        "previewUrl": { "type": ["string", "null"] },
        "previewCommand": { "type": ["string", "null"] },
        "routeScope": { "type": "object", "required": ["mode", "routes"] },
        "baselineUrls": { "type": "array", "items": { "type": "string" } },
        "packageManager": { "type": "string" },
        "buildCommand": { "type": ["string", "null"] },
        "testCommand": { "type": ["string", "null"] },
        "framework": { "type": "string" },
        "deploymentTarget": { "type": ["string", "null"] },
        "devicePriorities": { "type": "array", "items": { "type": "object", "required": ["name", "width"] } }
      }
    },
    "experienceArc": {
      "type": "object",
      "additionalProperties": false,
      "required": ["openingState", "firstTransformation", "sectionProgression", "peaksAndRests", "persistentSystem", "userControlledMoment", "mobileTranslation", "finalResolution"],
      "properties": {
        "openingState": { "type": "string" },
        "firstTransformation": { "type": "string" },
        "sectionProgression": { "type": "string" },
        "peaksAndRests": { "type": "string" },
        "persistentSystem": { "type": "string" },
        "userControlledMoment": { "type": "string" },
        "mobileTranslation": { "type": "string" },
        "finalResolution": { "type": "string" }
      }
    },
    "creativeSources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["references", "generatedImages", "sourcedImages", "generatedVideo", "sourcedVideo", "threeDAssets", "suppliedImageAssets", "suppliedVideoAssets", "suppliedThreeDAssets", "missingOrNeededAssets"],
      "properties": {
        "references": {
          "type": "object",
          "additionalProperties": false,
          "required": ["preference", "urls", "notes", "antiReferences"],
          "properties": {
            "preference": { "enum": ["provided", "none", "open-to-suggestions", null] },
            "urls": { "type": "array", "items": { "type": "string" } },
            "notes": { "type": "array", "items": { "type": "string" } },
            "antiReferences": { "type": "array", "items": { "type": "string" } }
          }
        },
        "generatedImages": { "$ref": "#/$defs/mediaPermission" },
        "sourcedImages": { "$ref": "#/$defs/mediaPermission" },
        "generatedVideo": { "$ref": "#/$defs/mediaPermission" },
        "sourcedVideo": { "$ref": "#/$defs/mediaPermission" },
        "threeDAssets": { "enum": ["not-allowed", "supplied-only", "external-sourcing-allowed", "generation-and-sourcing-allowed", "ask-per-asset", null] },
        "suppliedImageAssets": { "type": "array", "items": { "type": "string" } },
        "suppliedVideoAssets": { "type": "array", "items": { "type": "string" } },
        "suppliedThreeDAssets": { "type": "array", "items": { "type": "string" } },
        "missingOrNeededAssets": { "type": "array", "items": { "type": "string" } }
      }
    },
    "mediaPermission": { "enum": ["allowed", "not-allowed", "ask-per-asset", null] },
    "treatment": { "enum": ["ux", "mobile", "refined", "motion", "interaction", "media", "3d", "immersive", "cinematic", "experimental"] },
    "treatments": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/treatment" } }
  }
}
