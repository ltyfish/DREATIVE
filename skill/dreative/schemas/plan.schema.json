{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dreative.local/schemas/plan.schema.json",
  "title": "Dreative Multi-Page Direct Design Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "doctrineVersion", "request", "createdAt", "scope", "projectKind", "tier", "depth", "skills", "skillPolicy", "designRead", "coherence", "pages"],
  "allOf": [
    { "if": { "properties": { "scope": { "const": "substantial" } } }, "then": { "required": ["approval", "executionBrief", "commonPatternReview"] } },
    { "if": { "properties": { "scope": { "const": "substantial" }, "projectKind": { "const": "redesign" }, "depth": { "enum": ["restructure", "reimagine"] } } }, "then": { "required": ["creativeParity"] } }
  ],
  "properties": {
    "version": { "const": 5 },
    "doctrineVersion": { "const": 5 },
    "request": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "scope": { "enum": ["tiny", "substantial"] },
    "projectKind": { "enum": ["from-scratch", "redesign"] },
    "tier": { "enum": ["solid", "premium", "expressive", "award"] },
    "configuration": { "$ref": "#/$defs/configuration" },
    "depth": { "enum": ["restyle", "relayout", "restructure", "reimagine"] },
    "skills": { "$ref": "#/$defs/skillList" },
    "skillPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "global", "routingApproved", "userAssignments"],
      "properties": {
        "mode": { "const": "hybrid" },
        "global": { "$ref": "#/$defs/skillList" },
        "routingApproved": { "const": true },
        "userAssignments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pageId", "skills"],
            "properties": {
              "pageId": { "type": "string", "minLength": 1 },
              "skills": { "$ref": "#/$defs/treatmentList" }
            }
          }
        }
      }
    },
    "designRead": {
      "type": "object",
      "additionalProperties": false,
      "required": ["register", "concept", "signature"],
      "properties": {
        "register": { "type": "string", "minLength": 1 },
        "concept": { "type": "string", "minLength": 1 },
        "signature": { "type": "string", "minLength": 1 }
      }
    },
    "implementationStartedAt": { "type": "string", "format": "date-time" },
    "approval": { "$ref": "#/$defs/approval" },
    "designEquity": { "type": "string", "minLength": 1 },
    "checkpoint": { "type": "string", "minLength": 1 },
    "mockupStrategy": { "enum": ["mockup-first", "two-divergent-mockups", "build-with-checkpoint"] },
    "creativeParity": { "$ref": "#/$defs/creativeParity" },
    "executionBrief": { "$ref": "#/$defs/executionBrief" },
    "commonPatternReview": { "type": "array", "items": { "$ref": "#/$defs/commonPatternReview" } },
    "critic": { "type": "string", "minLength": 1 },
    "criticInput": { "type": "string", "minLength": 1 },
    "visualCritic": { "type": "string", "minLength": 1 },
    "ruleExceptions": { "type": "array", "items": { "$ref": "#/$defs/ruleException" } },
    "creativeStrategy": { "$ref": "#/$defs/creativeStrategy" },
    "motionComplexityBudget": { "$ref": "#/$defs/motionComplexityBudget" },
    "motionMoments": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/motionMoment" } },
    "mediaTransformations": { "type": "array", "items": { "$ref": "#/$defs/mediaTransformation" } },
    "signatureMedia": { "$ref": "#/$defs/signatureMedia" },
    "signatureMediaExemption": { "type": "string", "minLength": 20 },
    "fallbackExecutions": { "type": "array", "items": { "$ref": "#/$defs/fallbackExecution" } },
    "fontDecision": { "$ref": "#/$defs/fontDecision" },
    "experimentalPlan": { "$ref": "#/$defs/experimentalPlan" },
    "conceptExploration": { "$ref": "#/$defs/conceptExploration" },
    "recipeAccess": { "type": "array", "items": { "$ref": "#/$defs/recipeAccess" } },
    "coherence": { "$ref": "#/$defs/coherence" },
    "pages": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/page" } },
    "preservationManifest": { "type": "string", "minLength": 1 },
    "decisionLedger": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "configuration": {
      "type": "object", "additionalProperties": false,
      "required": ["ambition", "execution", "prototype", "purpose"],
      "properties": {
        "ambition": { "enum": ["standard", "expressive", "award", "experimental"] },
        "execution": { "enum": ["fast", "lean", "full-audit"] },
        "prototype": { "enum": ["skip", "auto", "required"] },
        "purpose": { "enum": ["project-delivery", "production-certification", "dreative-dogfood"] }
      }
    },
    "skill": { "enum": ["ux", "mobile", "refined", "motion", "interaction", "media", "3d", "immersive", "cinematic", "experimental"] },
    "skillList": {
      "type": "array",
      "uniqueItems": true,
      "allOf": [{ "contains": { "const": "ux" } }, { "contains": { "const": "mobile" } }],
      "items": { "$ref": "#/$defs/skill" }
    },
    "treatmentList": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/skill" }
    },
    "status": { "enum": ["planned", "shipped", "fallback", "cut"] },
    "approval": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "approvedAt", "approvedConcept", "approvedTransformationDepth", "approvedTier", "approvedTreatments", "selectedRecommendation", "decisions"],
      "properties": {
        "status": { "const": "approved" }, "approvedAt": { "type": "string", "format": "date-time" },
        "transcriptReferences": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "approvedConcept": { "type": "string", "minLength": 12 }, "approvedTransformationDepth": { "enum": ["restyle", "relayout", "restructure", "reimagine"] },
        "approvedTier": { "enum": ["solid", "premium", "expressive", "award"] }, "approvedTreatments": { "$ref": "#/$defs/treatmentList" },
        "selectedRecommendation": { "type": "boolean" },
        "decisions": { "type": "array", "minItems": 2, "items": { "type": "object", "additionalProperties": false, "required": ["kind", "at", "choice", "selectedRecommendation"], "properties": { "kind": { "enum": ["baseline", "concept", "final-plan"] }, "at": { "type": "string", "format": "date-time" }, "transcriptReference": { "type": "string", "minLength": 1 }, "choice": { "type": "string", "minLength": 12 }, "selectedRecommendation": { "type": "boolean" } } } }
      }
    },
    "creativeParity": {
      "type": "object", "additionalProperties": false,
      "required": ["fromScratchConcept", "reconciledConcept", "reconciliationChanges", "reconciliationWeakenedIdea", "retainedCreativeAmbition", "compromises"],
      "properties": { "fromScratchConcept": { "type": "string", "minLength": 30 }, "reconciledConcept": { "type": "string", "minLength": 30 }, "reconciliationChanges": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 12 } }, "reconciliationWeakenedIdea": { "type": "boolean" }, "retainedCreativeAmbition": { "type": "string", "minLength": 20 }, "compromises": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["compromise", "reason"], "properties": { "compromise": { "type": "string", "minLength": 12 }, "reason": { "type": "string", "minLength": 12 } } } } }
    },
    "executionBrief": {
      "type": "object", "additionalProperties": false,
      "required": ["approvedDecisions", "baselineDesignEquity", "selectedConcept", "preservationContracts", "selectedTreatmentRules", "checkpointRequirement", "criticRequirement", "verificationCriteria"],
      "properties": { "approvedDecisions": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 } }, "baselineDesignEquity": { "type": "array", "items": { "type": "string", "minLength": 1 } }, "selectedConcept": { "type": "string", "minLength": 20 }, "preservationContracts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }, "selectedTreatmentRules": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }, "checkpointRequirement": { "type": "string", "minLength": 12 }, "criticRequirement": { "type": "string", "minLength": 20 }, "verificationCriteria": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } }
    },
    "commonPatternReview": {
      "type": "object", "additionalProperties": false, "required": ["pattern", "decision", "rationale", "brandSpecificEvidence"],
      "properties": { "pattern": { "type": "string", "minLength": 1 }, "decision": { "enum": ["use", "revise"] }, "rationale": { "type": "string", "minLength": 20 }, "brandSpecificEvidence": { "type": "string", "minLength": 20 } }
    },
    "ruleException": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ruleId", "decision", "declaredAt", "reason", "alternative", "successCriteria", "evidenceIds"],
      "properties": {
        "ruleId": { "type": "string", "minLength": 1 },
        "decision": { "const": "substituted" },
        "declaredAt": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 20 },
        "alternative": { "type": "string", "minLength": 30 },
        "successCriteria": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 12 } },
        "evidenceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "creativeStrategy": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "mechanisms", "drivers"],
          "properties": {
            "path": { "const": "diversity" },
            "mechanisms": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
            "drivers": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "signatureMechanism", "states", "secondaryMechanisms", "drivers"],
          "properties": {
            "path": { "const": "development" },
            "signatureMechanism": { "type": "string", "minLength": 1 },
            "states": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "type": "string", "minLength": 12 } },
            "secondaryMechanisms": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
            "drivers": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
          }
        }
      ]
    },
    "motionComplexityBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["heroMoments", "calmSectionIds", "sharedLanguage", "deviceLimits", "progressiveEnhancement", "antiDefaultReview"],
      "properties": {
        "heroMoments": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sectionId", "reason"],
            "properties": {
              "sectionId": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 20 }
            }
          }
        },
        "calmSectionIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "sharedLanguage": { "type": "string", "minLength": 20 },
        "deviceLimits": { "type": "string", "minLength": 20 },
        "progressiveEnhancement": { "type": "string", "minLength": 20 },
        "antiDefaultReview": {
          "type": "object",
          "additionalProperties": false,
          "required": ["basicMotionAssessment", "compositionHandoff", "visualStateChange", "conceptSpecificity", "memorableMoment"],
          "properties": {
            "basicMotionAssessment": { "type": "string", "minLength": 20 },
            "compositionHandoff": { "type": "string", "minLength": 20 },
            "visualStateChange": { "type": "string", "minLength": 20 },
            "conceptSpecificity": { "type": "string", "minLength": 20 },
            "memorableMoment": { "type": "string", "minLength": 20 }
          }
        }
      }
    },
    "fontDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected", "candidates", "recentDisplayFonts"],
      "properties": {
        "selected": { "type": "string", "minLength": 1 },
        "candidates": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "reflex", "rationale"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "reflex": { "type": "boolean" },
              "rationale": { "type": "string", "minLength": 12 }
            }
          }
        },
        "recentDisplayFonts": { "type": "array", "maxItems": 3, "items": { "type": "string" } },
        "reasonKinds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": ["existing-brand", "design-system-metrics", "product-register", "supplied-reference", "language-coverage", "variable-font-capability", "performance", "physical-editorial-historical-reference"]
          }
        },
        "justification": { "type": "string", "minLength": 20 },
        "repeatJustification": { "type": "string", "minLength": 20 }
      }
    },
    "experimentalPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["majorSectionIds", "candidates"],
      "properties": {
        "majorSectionIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "sectionId", "idea", "selected"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "sectionId": { "type": "string", "minLength": 1 },
              "idea": { "type": "string", "minLength": 20 },
              "selected": { "type": "boolean" }
            }
          }
        }
      }
    },
    "conceptExploration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recordedAt", "concepts"],
      "properties": {
        "recordedAt": { "type": "string", "format": "date-time" },
        "concepts": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "concept", "brandConnection"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "concept": { "type": "string", "minLength": 20 },
              "brandConnection": { "type": "string", "minLength": 20 }
            }
          }
        }
      }
    },
    "recipeAccess": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "loadedAt", "purpose"],
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "loadedAt": { "type": "string", "format": "date-time" },
        "purpose": { "enum": ["feasibility", "implementation", "performance", "fallback", "concept-repair"] }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "purpose", "importance", "preparation", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "importance": { "enum": ["supporting", "key"] },
        "preparation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["decision", "derivatives", "rationale"],
          "properties": {
            "decision": { "enum": ["flat", "decompose", "variants", "sequence"] },
            "derivatives": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
            "rationale": { "type": "string", "minLength": 12 }
          }
        },
        "status": { "$ref": "#/$defs/status" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "layoutFamily", "visualBlueprint", "skills", "interactions", "mobile", "fallback", "verification", "assets", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "layoutFamily": { "type": "string", "minLength": 1 },
        "visualBlueprint": { "$ref": "#/$defs/visualBlueprint" },
        "skills": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/skill" } },
        "interactions": { "type": "array", "items": { "type": "string" } },
        "motionTreatment": { "$ref": "#/$defs/motionTreatment" },
        "motionMomentIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "mediaTransformationIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "mobile": { "type": "string", "minLength": 1 },
        "fallback": { "type": "string", "minLength": 1 },
        "verification": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/verificationCriterion" } },
        "assets": { "type": "array", "items": { "$ref": "#/$defs/asset" } },
        "status": { "$ref": "#/$defs/status" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "motionTreatment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "staticComposition", "startState", "endState", "changes", "pinnedElements", "handoff", "purpose", "mechanism", "mobile", "reducedMotion"],
      "properties": {
        "class": { "enum": ["none", "decorative", "structural", "transformational"] },
        "staticComposition": { "type": "string", "minLength": 12 },
        "startState": { "type": "string", "minLength": 12 },
        "endState": { "type": "string", "minLength": 12 },
        "changes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "pinnedElements": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "handoff": { "type": "string", "minLength": 12 },
        "purpose": { "type": "string", "minLength": 12 },
        "mechanism": { "type": "string", "minLength": 12 },
        "mobile": { "type": "string", "minLength": 12 },
        "reducedMotion": { "type": "string", "minLength": 12 }
      }
    },
    "motionMoment": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "pageId", "sectionId", "owner", "class", "driver", "staticComposition", "startState", "intermediateState", "endState", "handoff", "purpose", "renderingMechanism", "implementationFile", "implementationComponent", "observedProperties", "desktop", "mobile", "reducedMotion", "primaryImplementation", "runtimeFallback", "successCriteria", "requiredEvidenceIds", "hero"],
      "properties": {
        "id": { "type": "string", "minLength": 3 }, "pageId": { "type": "string", "minLength": 1 }, "sectionId": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 12 }, "class": { "enum": ["decorative", "structural", "transformational"] }, "driver": { "type": "string", "minLength": 3 },
        "staticComposition": { "$ref": "#/$defs/concrete" }, "startState": { "$ref": "#/$defs/concrete" }, "intermediateState": { "$ref": "#/$defs/concrete" }, "endState": { "$ref": "#/$defs/concrete" },
        "handoff": { "$ref": "#/$defs/concrete" }, "purpose": { "$ref": "#/$defs/concrete" }, "renderingMechanism": { "$ref": "#/$defs/concrete" },
        "implementationFile": { "type": "string", "minLength": 3 }, "implementationComponent": { "type": "string", "minLength": 3 },
        "observedProperties": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 3 } },
        "desktop": { "$ref": "#/$defs/concrete" }, "mobile": { "$ref": "#/$defs/concrete" }, "reducedMotion": { "$ref": "#/$defs/concrete" },
        "primaryImplementation": { "$ref": "#/$defs/concrete" }, "runtimeFallback": { "$ref": "#/$defs/concrete" },
        "successCriteria": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 20 } },
        "requiredEvidenceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "hero": { "type": "boolean" }
      }
    },
    "fallbackExecution": {
      "type": "object", "additionalProperties": false, "required": ["sectionId", "primaryAttempted", "failureEvidenceIds", "fallbackSuccessEvidenceIds", "finalTierSatisfied", "reason"],
      "properties": { "sectionId": { "type": "string", "minLength": 1 }, "motionMomentId": { "type": "string", "minLength": 1 }, "primaryAttempted": { "const": true }, "failureEvidenceIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }, "fallbackSuccessEvidenceIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }, "finalTierSatisfied": { "type": "boolean" }, "reason": { "$ref": "#/$defs/concrete" }, "userApprovalReference": { "type": "string", "minLength": 1 } }
    },
    "mediaTransformation": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "pageId", "sectionId", "motionMomentId", "sourceAsset", "candidates", "selectedCandidateId", "mechanismComparison", "derivatives", "consistencyInspection", "finalEvidenceIds", "implementationFile"],
      "properties": {
        "id": { "type": "string", "minLength": 3 }, "pageId": { "type": "string", "minLength": 1 }, "sectionId": { "type": "string", "minLength": 1 }, "motionMomentId": { "type": "string", "minLength": 1 }, "sourceAsset": { "type": "string", "minLength": 3 }, "selectedCandidateId": { "type": "string", "minLength": 1 }, "implementationFile": { "type": "string", "minLength": 3 }, "consistencyInspection": { "$ref": "#/$defs/concrete" },
        "candidates": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "$ref": "#/$defs/transformationCandidate" } },
        "mechanismComparison": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["mechanism", "feasibility", "decision", "reason"], "properties": { "mechanism": { "enum": ["DOM/CSS", "SVG", "Canvas 2D", "WebGL shader", "Three.js scene", "image sequence", "pre-rendered video", "hybrid composition"] }, "feasibility": { "$ref": "#/$defs/concrete" }, "decision": { "enum": ["selected", "rejected"] }, "reason": { "$ref": "#/$defs/concrete" } } } },
        "derivatives": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/transformationDerivative" } },
        "frameSequence": { "$ref": "#/$defs/frameSequence" },
        "prototypeEvidenceIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }, "finalEvidenceIds": { "$ref": "#/$defs/evidenceIds" }
      }
    },
    "signatureMedia": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "type", "pageId", "sectionId", "purpose", "sourceAssets", "derivatives", "implementationFile", "runtimeReferences", "independentlyControlledElements", "mobileFallback", "reducedMotionFallback", "performanceSafeguards", "evidenceIds"],
      "properties": {
        "id": { "type": "string", "minLength": 3 },
        "type": { "enum": ["layered-subject", "depth-separated", "fragment-reconstruction", "tile-atlas", "generated-states", "frame-sequence", "canvas", "webgl", "editorial-cut-up", "clean-plate"] },
        "pageId": { "type": "string", "minLength": 1 }, "sectionId": { "type": "string", "minLength": 1 }, "purpose": { "type": "string", "minLength": 20 },
        "sourceAssets": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "derivatives": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["path", "role"], "properties": { "path": { "type": "string", "minLength": 1 }, "role": { "type": "string", "minLength": 1 } } } },
        "implementationFile": { "type": "string", "minLength": 1 },
        "runtimeReferences": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
