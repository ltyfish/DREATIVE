{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dreative.local/schemas/plan.schema.json",
  "title": "Dreative Multi-Page Direct Design Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "doctrineVersion", "request", "createdAt", "scope", "projectKind", "tier", "depth", "skills", "skillPolicy", "designRead", "coherence", "pages", "preservationManifest", "decisionLedger"],
  "allOf": [
    { "if": { "properties": { "scope": { "const": "substantial" } } }, "then": { "required": ["approval", "executionBrief", "commonPatternReview"] } },
    { "if": { "properties": { "scope": { "const": "substantial" }, "projectKind": { "const": "redesign" } } }, "then": { "required": ["designEquity"] } },
    { "if": { "properties": { "scope": { "const": "substantial" }, "projectKind": { "const": "redesign" }, "depth": { "enum": ["restructure", "reimagine"] } } }, "then": { "required": ["checkpoint", "creativeParity"] } }
  ],
  "properties": {
    "version": { "const": 4 },
    "doctrineVersion": { "const": 4 },
    "request": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "scope": { "enum": ["tiny", "substantial"] },
    "projectKind": { "enum": ["from-scratch", "redesign"] },
    "tier": { "enum": ["solid", "premium", "expressive", "award"] },
    "depth": { "enum": ["restyle", "relayout", "restructure", "reimagine"] },
    "skills": { "$ref": "#/$defs/skillList" },
    "skillPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "global", "routingApproved", "userAssignments"],
      "properties": {
        "mode": { "const": "hybrid" },
        "global": { "$ref": "#/$defs/skillList" },
        "routingApproved": { "const": true },
        "userAssignments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pageId", "skills"],
            "properties": {
              "pageId": { "type": "string", "minLength": 1 },
              "skills": { "$ref": "#/$defs/treatmentList" }
            }
          }
        }
      }
    },
    "designRead": {
      "type": "object",
      "additionalProperties": false,
      "required": ["register", "concept", "signature"],
      "properties": {
        "register": { "type": "string", "minLength": 1 },
        "concept": { "type": "string", "minLength": 1 },
        "signature": { "type": "string", "minLength": 1 }
      }
    },
    "implementationStartedAt": { "type": "string", "format": "date-time" },
    "approval": { "$ref": "#/$defs/approval" },
    "designEquity": { "type": "string", "minLength": 1 },
    "checkpoint": { "type": "string", "minLength": 1 },
    "mockupStrategy": { "enum": ["mockup-first", "straight-to-build"] },
    "creativeParity": { "$ref": "#/$defs/creativeParity" },
    "executionBrief": { "$ref": "#/$defs/executionBrief" },
    "commonPatternReview": { "type": "array", "items": { "$ref": "#/$defs/commonPatternReview" } },
    "ruleExceptions": { "type": "array", "items": { "$ref": "#/$defs/ruleException" } },
    "creativeStrategy": { "$ref": "#/$defs/creativeStrategy" },
    "motionComplexityBudget": { "$ref": "#/$defs/motionComplexityBudget" },
    "fontDecision": { "$ref": "#/$defs/fontDecision" },
    "experimentalPlan": { "$ref": "#/$defs/experimentalPlan" },
    "conceptExploration": { "$ref": "#/$defs/conceptExploration" },
    "recipeAccess": { "type": "array", "items": { "$ref": "#/$defs/recipeAccess" } },
    "coherence": { "$ref": "#/$defs/coherence" },
    "pages": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/page" } },
    "preservationManifest": { "type": "string", "minLength": 1 },
    "decisionLedger": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "skill": { "enum": ["ux", "mobile", "refined", "motion", "interaction", "media", "3d", "immersive", "cinematic", "experimental"] },
    "skillList": {
      "type": "array",
      "uniqueItems": true,
      "allOf": [{ "contains": { "const": "ux" } }, { "contains": { "const": "mobile" } }],
      "items": { "$ref": "#/$defs/skill" }
    },
    "treatmentList": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/skill" }
    },
    "status": { "enum": ["planned", "shipped", "fallback", "cut"] },
    "approval": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "approvedAt", "transcriptReferences", "approvedConcept", "approvedTransformationDepth", "approvedTier", "approvedTreatments", "selectedRecommendation", "decisions"],
      "properties": {
        "status": { "const": "approved" }, "approvedAt": { "type": "string", "format": "date-time" },
        "transcriptReferences": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "approvedConcept": { "type": "string", "minLength": 12 }, "approvedTransformationDepth": { "enum": ["restyle", "relayout", "restructure", "reimagine"] },
        "approvedTier": { "enum": ["solid", "premium", "expressive", "award"] }, "approvedTreatments": { "$ref": "#/$defs/treatmentList" },
        "selectedRecommendation": { "type": "boolean" },
        "decisions": { "type": "array", "minItems": 2, "items": { "type": "object", "additionalProperties": false, "required": ["kind", "at", "transcriptReference", "choice", "selectedRecommendation"], "properties": { "kind": { "enum": ["baseline", "concept", "final-plan"] }, "at": { "type": "string", "format": "date-time" }, "transcriptReference": { "type": "string", "minLength": 1 }, "choice": { "type": "string", "minLength": 12 }, "selectedRecommendation": { "type": "boolean" } } } }
      }
    },
    "creativeParity": {
      "type": "object", "additionalProperties": false,
      "required": ["fromScratchConcept", "reconciledConcept", "reconciliationChanges", "reconciliationWeakenedIdea", "retainedCreativeAmbition", "compromises"],
      "properties": { "fromScratchConcept": { "type": "string", "minLength": 30 }, "reconciledConcept": { "type": "string", "minLength": 30 }, "reconciliationChanges": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 12 } }, "reconciliationWeakenedIdea": { "type": "boolean" }, "retainedCreativeAmbition": { "type": "string", "minLength": 20 }, "compromises": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["compromise", "reason"], "properties": { "compromise": { "type": "string", "minLength": 12 }, "reason": { "type": "string", "minLength": 12 } } } } }
    },
    "executionBrief": {
      "type": "object", "additionalProperties": false,
      "required": ["approvedDecisions", "baselineDesignEquity", "selectedConcept", "preservationContracts", "selectedTreatmentRules", "checkpointRequirement", "verificationCriteria"],
      "properties": { "approvedDecisions": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 } }, "baselineDesignEquity": { "type": "array", "items": { "type": "string", "minLength": 1 } }, "selectedConcept": { "type": "string", "minLength": 20 }, "preservationContracts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }, "selectedTreatmentRules": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }, "checkpointRequirement": { "type": "string", "minLength": 12 }, "verificationCriteria": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } }
    },
    "commonPatternReview": {
      "type": "object", "additionalProperties": false, "required": ["pattern", "decision", "rationale", "brandSpecificEvidence"],
      "properties": { "pattern": { "type": "string", "minLength": 1 }, "decision": { "enum": ["use", "revise"] }, "rationale": { "type": "string", "minLength": 20 }, "brandSpecificEvidence": { "type": "string", "minLength": 20 } }
    },
    "ruleException": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ruleId", "decision", "declaredAt", "reason", "alternative", "successCriteria", "evidenceIds"],
      "properties": {
        "ruleId": { "type": "string", "minLength": 1 },
        "decision": { "const": "substituted" },
        "declaredAt": { "type": "string", "format": "date-time" },
        "reason": { "type": "string", "minLength": 20 },
        "alternative": { "type": "string", "minLength": 30 },
        "successCriteria": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 12 } },
        "evidenceIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "creativeStrategy": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "mechanisms", "drivers"],
          "properties": {
            "path": { "const": "diversity" },
            "mechanisms": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
            "drivers": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "signatureMechanism", "states", "secondaryMechanisms", "drivers"],
          "properties": {
            "path": { "const": "development" },
            "signatureMechanism": { "type": "string", "minLength": 1 },
            "states": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "type": "string", "minLength": 12 } },
            "secondaryMechanisms": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
            "drivers": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
          }
        }
      ]
    },
    "motionComplexityBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["heroMoments", "calmSectionIds", "sharedLanguage", "deviceLimits", "progressiveEnhancement", "antiDefaultReview"],
      "properties": {
        "heroMoments": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sectionId", "reason"],
            "properties": {
              "sectionId": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 20 }
            }
          }
        },
        "calmSectionIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "sharedLanguage": { "type": "string", "minLength": 20 },
        "deviceLimits": { "type": "string", "minLength": 20 },
        "progressiveEnhancement": { "type": "string", "minLength": 20 },
        "antiDefaultReview": {
          "type": "object",
          "additionalProperties": false,
          "required": ["basicMotionAssessment", "compositionHandoff", "visualStateChange", "conceptSpecificity", "memorableMoment"],
          "properties": {
            "basicMotionAssessment": { "type": "string", "minLength": 20 },
            "compositionHandoff": { "type": "string", "minLength": 20 },
            "visualStateChange": { "type": "string", "minLength": 20 },
            "conceptSpecificity": { "type": "string", "minLength": 20 },
            "memorableMoment": { "type": "string", "minLength": 20 }
          }
        }
      }
    },
    "fontDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selected", "candidates", "recentDisplayFonts"],
      "properties": {
        "selected": { "type": "string", "minLength": 1 },
        "candidates": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "reflex", "rationale"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "reflex": { "type": "boolean" },
              "rationale": { "type": "string", "minLength": 12 }
            }
          }
        },
        "recentDisplayFonts": { "type": "array", "maxItems": 3, "items": { "type": "string" } },
        "reasonKinds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": ["existing-brand", "design-system-metrics", "product-register", "supplied-reference", "language-coverage", "variable-font-capability", "performance", "physical-editorial-historical-reference"]
          }
        },
        "justification": { "type": "string", "minLength": 20 },
        "repeatJustification": { "type": "string", "minLength": 20 }
      }
    },
    "experimentalPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["majorSectionIds", "candidates"],
      "properties": {
        "majorSectionIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "sectionId", "idea", "selected"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "sectionId": { "type": "string", "minLength": 1 },
              "idea": { "type": "string", "minLength": 20 },
              "selected": { "type": "boolean" }
            }
          }
        }
      }
    },
    "conceptExploration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recordedAt", "concepts"],
      "properties": {
        "recordedAt": { "type": "string", "format": "date-time" },
        "concepts": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "concept", "brandConnection"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "concept": { "type": "string", "minLength": 20 },
              "brandConnection": { "type": "string", "minLength": 20 }
            }
          }
        }
      }
    },
    "recipeAccess": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "loadedAt", "purpose"],
      "properties": {
        "file": { "type": "string", "minLength": 1 },
        "loadedAt": { "type": "string", "format": "date-time" },
        "purpose": { "enum": ["feasibility", "implementation", "performance", "fallback", "concept-repair"] }
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "purpose", "importance", "preparation", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "importance": { "enum": ["supporting", "key"] },
        "preparation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["decision", "derivatives", "rationale"],
          "properties": {
            "decision": { "enum": ["flat", "decompose", "variants", "sequence"] },
            "derivatives": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
            "rationale": { "type": "string", "minLength": 12 }
          }
        },
        "status": { "$ref": "#/$defs/status" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "layoutFamily", "visualBlueprint", "skills", "interactions", "mobile", "fallback", "verification", "assets", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "layoutFamily": { "type": "string", "minLength": 1 },
        "visualBlueprint": { "$ref": "#/$defs/visualBlueprint" },
        "skills": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/skill" } },
        "interactions": { "type": "array", "items": { "type": "string" } },
        "motionTreatment": { "$ref": "#/$defs/motionTreatment" },
        "mobile": { "type": "string", "minLength": 1 },
        "fallback": { "type": "string", "minLength": 1 },
        "verification": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/verificationCriterion" } },
        "assets": { "type": "array", "items": { "$ref": "#/$defs/asset" } },
        "status": { "$ref": "#/$defs/status" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "motionTreatment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "staticComposition", "startState", "endState", "changes", "pinnedElements", "handoff", "purpose", "mechanism", "mobile", "reducedMotion"],
      "properties": {
        "class": { "enum": ["none", "decorative", "structural", "transformational"] },
        "staticComposition": { "type": "string", "minLength": 12 },
        "startState": { "type": "string", "minLength": 12 },
        "endState": { "type": "string", "minLength": 12 },
        "changes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "pinnedElements": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "handoff": { "type": "string", "minLength": 12 },
        "purpose": { "type": "string", "minLength": 12 },
        "mechanism": { "type": "string", "minLength": 12 },
        "mobile": { "type": "string", "minLength": 12 },
        "reducedMotion": { "type": "string", "minLength": 12 }
      }
    },
    "verificationCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "claim", "kind", "pageId", "viewports"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "claim": { "type": "string", "minLength": 12 },
        "kind": { "enum": ["visual", "interaction", "responsive", "preservation", "structural-depth", "design-equity", "concept-fidelity", "perceptual-comparison", "visual-regression"] },
        "pageId": { "type": "string", "minLength": 1 },
        "sectionId": { "type": "string", "minLength": 1 },
        "viewports": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["desktop", "mobile", "narrow-mobile", "non-visual"] } }
      }
    },
    "pageRegister": { "enum": ["marketing-storytelling", "discovery-browse", "task-transaction", "account-status", "administration", "data-dense-utility", "authentication", "system-state"] },
    "visualBlueprint": {
      "type": "object", "additionalProperties": false,
      "required": ["viewportComposition", "spatialRatios", "primaryFocal", "secondaryFocal", "gridLogic", "typographyRoles", "materialRelationship", "brandMotif", "signatureLocation", "signatureRole", "interactionDriver", "motionStart", "motionEnd", "sectionHandoff", "mobileRecomposition", "reducedMotion", "commonTemplateRisk", "brandSpecificity"],
      "properties": {
        "viewportComposition": { "type": "string", "minLength": 12 }, "spatialRatios": { "type": "string", "minLength": 12 }, "primaryFocal": { "type": "string", "minLength": 12 }, "secondaryFocal": { "type": "string", "minLength": 12 }, "gridLogic": { "type": "string", "minLength": 12 }, "typographyRoles": { "type": "string", "minLength": 12 }, "materialRelationship": { "type": "string", "minLength": 12 }, "brandMotif": { "type": "string", "minLength": 12 }, "signatureLocation": { "type": "string", "minLength": 12 }, "signatureRole": { "type": "string", "minLength": 12 }, "interactionDriver": { "type": "string", "minLength": 12 }, "motionStart": { "type": "string", "minLength": 12 }, "motionEnd": { "type": "string", "minLength": 12 }, "sectionHandoff": { "type": "string", "minLength": 12 }, "mobileRecomposition": { "type": "string", "minLength": 12 }, "reducedMotion": { "type": "string", "minLength": 12 }, "commonTemplateRisk": { "type": "string", "minLength": 12 }, "brandSpecificity": { "type": "string", "minLength": 12 }
      }
    },
    "structuralDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["existingModel", "proposedModel", "existingParadigm", "proposedParadigm", "materialChanges", "survivingBoundaries", "rebuiltBoundaries", "preservedContracts", "retainedPatterns", "forbiddenCarryovers", "depthHonesty"],
      "properties": {
        "existingModel": { "type": "string", "minLength": 12 },
        "proposedModel": { "type": "string", "minLength": 12 },
        "existingParadigm": { "type": "string", "minLength": 12 },
        "proposedParadigm": { "type": "string", "minLength": 12 },
        "materialChanges": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 12 } },
        "survivingBoundaries": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "rebuiltBoundaries": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "preservedContracts": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "retainedPatterns": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["pattern", "rationale"], "properties": { "pattern": { "type": "string", "minLength": 1 }, "rationale": { "type": "string", "minLength": 12 } } } },
        "forbiddenCarryovers": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "depthHonesty": { "type": "string", "minLength": 20 }
      }
    },
    "mobileBlueprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primaryTask", "firstViewportPurpose", "contentOrder", "beforeFirstScroll", "primaryThumbAction", "stickyElements", "safeArea", "navigationModel", "mobileOnlyComposition", "desktopTranslation", "mediaStrategy", "motionStrategy", "keyboardAndForms", "composition390", "fallback320", "stackingRejection", "verificationChecks"],
      "properties": {
        "primaryTask": { "type": "string", "minLength": 1 },
        "firstViewportPurpose": { "type": "string", "minLength": 12 },
        "contentOrder": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 } },
        "beforeFirstScroll": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "primaryThumbAction": { "type": "object", "additionalProperties": false, "required": ["action", "placement"], "properties": { "action": { "type": "string", "minLength": 1 }, "placement": { "type": "string", "minLength": 12 } } },
        "stickyElements": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "safeArea": { "type": "string", "minLength": 12 },
        "navigationModel": { "type": "string", "minLength": 12 },
        "mobileOnlyComposition": { "type": "string", "minLength": 12 },
        "desktopTranslation": { "type": "object", "additionalProperties": false, "required": ["retained", "translated", "removed", "replaced"], "properties": { "retained": { "type": "array", "items": { "type": "string" } }, "translated": { "type": "array", "items": { "type": "string" } }, "removed": { "type": "array", "items": { "type": "string" } }, "replaced": { "type": "array", "items": { "type": "string" } } } },
        "mediaStrategy": { "type": "string", "minLength": 12 },
        "motionStrategy": { "type": "string", "minLength": 12 },
        "keyboardAndForms": { "type": "string", "minLength": 12 },
        "composition390": { "type": "string", "minLength": 12 },
        "fallback320": { "type": "string", "minLength": 12 },
        "stackingRejection": { "type": "string", "minLength": 12 },
        "verificationChecks": { "type": "array", "minItems": 13, "uniqueItems": true, "items": { "enum": ["no-horizontal-overflow", "no-clipped-content", "fixed-elements-clear-content", "safe-area-spacing", "primary-task-discoverable", "primary-action-reachable", "touch-targets", "software-keyboard-usable", "no-hover-only", "intentional-mobile-composition", "mobile-content-order", "motion-media-translated", "no-decorative-task-blocker"] } }
      }
    },
    "expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mechanism", "communicates", "projectFit", "location", "mobileTranslation", "reducedMotion", "fallback", "verification"],
      "properties": {
        "mechanism": { "type": "string", "minLength": 12 }, "communicates": { "type": "string", "minLength": 12 }, "projectFit": { "type": "string", "minLength": 12 }, "location": { "type": "string", "minLength": 12 }, "mobileTranslation": { "type": "string", "minLength": 12 }, "reducedMotion": { "type": "string", "minLength": 12 }, "fallback": { "type": "string", "minLength": 12 }, "verification": { "type": "string", "minLength": 12 }
      }
    },
    "coherence": {
      "type": "object", "additionalProperties": false,
      "required": ["globalVisualLanguage", "globalInteractionLanguage", "sharedPrimitives", "pageSpecificCompositions", "crossPageContinuity", "prohibitedRepeatedShells"],
      "properties": {
        "globalVisualLanguage": { "type": "string", "minLength": 12 }, "globalInteractionLanguage": { "type": "string", "minLength": 12 },
        "sharedPrimitives": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "pageSpecificCompositions": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["pageId", "register", "taskModel", "expressionLevel"], "properties": { "pageId": { "type": "string", "minLength": 1 }, "register": { "$ref": "#/$defs/pageRegister" }, "taskModel": { "type": "string", "minLength": 12 }, "expressionLevel": { "enum": ["calm", "authored"] } } } },
        "crossPageContinuity": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "prohibitedRepeatedShells": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "register", "sourceStrategy", "structuralDelta", "mobileBlueprint", "skills", "sections"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "register": { "$ref": "#/$defs/pageRegister" },
        "sourceStrategy": { "enum": ["patch", "recompose", "rebuild-from-contracts"] },
        "structuralDelta": { "$ref": "#/$defs/structuralDelta" },
        "mobileBlueprint": { "$ref": "#/$defs/mobileBlueprint" },
        "expression": { "$ref": "#/$defs/expression" },
        "intentionalCalm": { "type": "string", "minLength": 20 },
        "skills": { "$ref": "#/$defs/skillList" },
        "sections": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/section" } }
      }
    }
  }
}
