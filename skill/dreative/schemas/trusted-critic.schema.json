{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dreative.local/schemas/trusted-critic.schema.json",
  "title": "Dreative Critic Evidence Run v2",
  "description": "The filename is retained for compatibility. Provider class and assurance determine whether this is advisory, host-isolated, or externally attested.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "runId", "nonce", "runnerIdentity", "providerId", "providerClass", "assuranceLevel", "startedAt", "finishedAt", "approvedPlanHash", "sourceHash", "buildHash", "verificationRunId", "inputArtifactHashes", "reportHash", "artifact", "computedResult"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "runId": { "type": "string" },
    "nonce": { "type": "string", "minLength": 32 },
    "runnerIdentity": { "$ref": "#/$defs/hash" },
    "providerId": { "type": "string" },
    "providerClass": { "enum": ["project-local-advisory", "host-isolated", "externally-attested"] },
    "assuranceLevel": { "enum": ["local", "host-attested", "externally-attested"] },
    "processId": { "type": ["integer", "null"] },
    "startedAt": { "type": "string", "format": "date-time" },
    "finishedAt": { "type": "string", "format": "date-time" },
    "approvedPlanHash": { "$ref": "#/$defs/hash" },
    "sourceHash": { "$ref": "#/$defs/hash" },
    "buildHash": { "$ref": "#/$defs/hash" },
    "verificationRunId": { "type": "string" },
    "inputArtifactHashes": { "type": "object", "additionalProperties": { "$ref": "#/$defs/hash" } },
    "reportHash": { "$ref": "#/$defs/hash" },
    "artifact": { "type": "object", "required": ["id", "type", "path", "sha256", "bytes"] },
    "computedResult": { "type": "object" }
  },
  "$defs": { "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" } }
}
